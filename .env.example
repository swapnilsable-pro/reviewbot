# Required: OpenRouter API key — get a free one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Required: GitHub token with pull-requests: write scope.
# In GitHub Actions this is injected automatically as ${{ secrets.GITHUB_TOKEN }}.
GITHUB_TOKEN=ghp_...

# Optional (only for running locally outside of GitHub Actions):
# GITHUB_REPOSITORY=owner/repo
# REVIEWBOT_PR_NUMBER=123
